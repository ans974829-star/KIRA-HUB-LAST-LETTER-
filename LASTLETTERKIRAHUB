local function SmoothTween(obj, duration, props, style, direction)
    return TweenService:Create(obj, TweenInfo.new(duration, style or Enum.EasingStyle.Quint, direction or Enum.EasingDirection.Out), props)
end

local function ParallaxBackground()
    task.spawn(function()
        local angle = 0
        while BackgroundImage and BackgroundImage.Parent do
            angle = angle + 0.002
            local xOffset = math.sin(angle) * 0.03
            local yOffset = math.cos(angle * 0.7) * 0.02
            BackgroundImage.Position = UDim2.new(0.5 + xOffset, 0, 0.5 + yOffset, 0)
            task.wait()
        end
    end)
end

local function PulseGlow(glow, minTrans, maxTrans, duration)
    task.spawn(function()
        while glow and glow.Parent do
            SmoothTween(glow, duration, {ImageTransparency = minTrans}, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut):Play()
            task.wait(duration)
            SmoothTween(glow, duration, {ImageTransparency = maxTrans}, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut):Play()
            task.wait(duration)
        end
    end)
end

local function ColorShift(obj, prop, color1, color2, duration)
    task.spawn(function()
        while obj and obj.Parent do
            SmoothTween(obj, duration, {[prop] = color2}, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut):Play()
            task.wait(duration)
            SmoothTween(obj, duration, {[prop] = color1}, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut):Play()
            task.wait(duration)
        end
    end)
end

local function SubtleHover(element, offsetY)
    local originalY = element.Position.Y.Offset
    task.spawn(function()
        while element and element.Parent do
            SmoothTween(element, 2, {Position = UDim2.new(element.Position.X.Scale, element.Position.X.Offset, element.Position.Y.Scale, originalY - offsetY)}, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut):Play()
            task.wait(2)
            SmoothTween(element, 2, {Position = UDim2.new(element.Position.X.Scale, element.Position.X.Offset, element.Position.Y.Scale, originalY + offsetY)}, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut):Play()
            task.wait(2)
        end
    end)
end

