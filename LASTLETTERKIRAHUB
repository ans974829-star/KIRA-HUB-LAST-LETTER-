-- 🎬 ANIMATION SEQUENCES
-- ═══════════════════════════════════════════════════════════════

local function TypeText(label, text, speed)
    label.Text = ""
    for i = 1, #text do
        label.Text = text:sub(1, i)
        task.wait(speed or 0.03)
    end
end

local function ShakeElement(element, intensity, duration)
    local originalPos = element.Position
    local startTime = tick()
    
    while tick() - startTime < duration do
        local offsetX = math.random(-intensity, intensity)
        local offsetY = math.random(-intensity, intensity)
        element.Position = UDim2.new(
            originalPos.X.Scale, originalPos.X.Offset + offsetX,
            originalPos.Y.Scale, originalPos.Y.Offset + offsetY
        )
        task.wait(0.02)
    end
    
    element.Position = originalPos
end

local function PulseElement(element, property, minVal, maxVal, duration)
    task.spawn(function()
        while element and element.Parent do
            TweenService:Create(element, TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                [property] = maxVal
            }):Play()
            task.wait(duration)
            TweenService:Create(element, TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                [property] = minVal
            }):Play()
            task.wait(duration)
        end
    end)
end

local function FloatElement(element, amplitude, duration)
    local originalY = element.Position.Y.Offset
    task.spawn(function()
        while element and element.Parent do
            TweenService:Create(element, TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Position = UDim2.new(element.Position.X.Scale, element.Position.X.Offset, element.Position.Y.Scale, originalY - amplitude)
            }):Play()
            task.wait(duration)
            TweenService:Create(element, TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Position = UDim2.new(element.Position.X.Scale, element.Position.X.Offset, element.Position.Y.Scale, originalY + amplitude)
            }):Play()
            task.wait(duration)
        end
    end)
end

local function ColorCycle(element, property, colors, duration)
    task.spawn(function()
        local index = 1
        while element and element.Parent do
            local nextIndex = index % #colors + 1
            TweenService:Create(element, TweenInfo.new(duration, Enum.EasingStyle.Sine), {
                [property] = colors[nextIndex]
            }):Play()
            task.wait(duration)
            index = nextIndex
        end
    end)
end

local function RotateSlow(element, duration)
    task.spawn(function()
        while element and element.Parent do
            TweenService:Create(element, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
                Rotation = element.Rotation + 360
            }):Play()
            task.wait(duration)
        end
    end)
end

