-- 🪑 TABLE AUTO-JOIN SYSTEM (LAST LETTER HALL ONLY)
-- ═══════════════════════════════════════════════════════════════

local function GetTableStatus(tableNum)
    local tbl = workspace.Tables:FindFirstChild(tostring(tableNum))
    if not tbl then return nil end
    local billboard = tbl:FindFirstChild("Billboard")
    if not billboard then return nil end
    
    for _, obj in pairs(billboard:GetDescendants()) do
        if obj:IsA("TextLabel") then
            local current, max = obj.Text:match("(%d+)/(%d+)")
            if current and max then
                return {
                    current = tonumber(current),
                    max = tonumber(max),
                    full = tonumber(current) >= tonumber(max),
                    table = tbl,
                    billboard = billboard
                }
            end
        end
    end
    return nil
end

local function GetAvailableTables(mode)
    local tables = TABLE_CONFIG[mode]
    if not tables then return {} end
    local available = {}
    for _, tableNum in ipairs(tables) do
        local status = GetTableStatus(tableNum)
        if status and not status.full then
            table.insert(available, {
                number = tableNum,
                status = status,
                position = status.table:GetPivot().Position
            })
        end
    end
    return available
end

local function TeleportToTable(tableNum)
    local tbl = workspace.Tables:FindFirstChild(tostring(tableNum))
    if not tbl then return false, "Table not found" end
    
    local billboard = tbl:FindFirstChild("Billboard")
    if not billboard then return false, "Billboard not found" end
    
    local char = player.Character
    if not char then return false, "No character" end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false, "No HumanoidRootPart" end
    
    local targetPos = billboard:GetPivot().Position + Vector3.new(0, 3, 5)
    hrp.CFrame = CFrame.new(targetPos)
    task.wait(0.3)
    
    local prompt = billboard:FindFirstChild("Prompt", true)
    if prompt and prompt:IsA("ProximityPrompt") then
        fireproximityprompt(prompt)
        return true, "Joined Table #" .. tableNum .. "!"
    end
    return false, "Prompt not found"
end

local function JoinGameMode(mode)
    local available = GetAvailableTables(mode)
    if #available == 0 then
        return false, "All " .. mode .. " tables occupied!"
    end
    
    local char = player.Character
    if not char then return false, "No character" end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false, "No HumanoidRootPart" end
    
    local playerPos = hrp.Position
    local nearest = available[1]
    local nearestDist = (playerPos - nearest.position).Magnitude
    
    for i = 2, #available do
        local dist = (playerPos - available[i].position).Magnitude
        if dist < nearestDist then
            nearest = available[i]
            nearestDist = dist
        end
    end
    
    return TeleportToTable(nearest.number)
end

