task.spawn(function()
    -- Phase 1: Blur and Background
    TweenService:Create(BlurEffect, TweenInfo.new(0.8, Enum.EasingStyle.Quint), {Size = 30}):Play()
    TweenService:Create(BackgroundFrame, TweenInfo.new(0.5), {BackgroundTransparency = 0}):Play()
    task.wait(0.3)
    
    TweenService:Create(BackgroundImage, TweenInfo.new(1, Enum.EasingStyle.Quint), {ImageTransparency = 0.15}):Play()
    task.wait(0.3)
    
    TweenService:Create(DarkOverlay, TweenInfo.new(0.8), {BackgroundTransparency = 0.4}):Play()
    TweenService:Create(Vignette, TweenInfo.new(1), {ImageTransparency = 0.3}):Play()
    task.wait(0.5)
    
    -- Start background animation (slow zoom/pan)
    task.spawn(function()
        while BackgroundImage and BackgroundImage.Parent do
            TweenService:Create(BackgroundImage, TweenInfo.new(10, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Position = UDim2.new(-0.05, 0, -0.15, 0)
            }):Play()
            task.wait(10)
            TweenService:Create(BackgroundImage, TweenInfo.new(10, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Position = UDim2.new(-0.15, 0, -0.05, 0)
            }):Play()
            task.wait(10)
        end
    end)
    
    -- Start particles
    task.spawn(function()
        while ParticleContainer and ParticleContainer.Parent do
            CreateParticle()
            task.wait(math.random(100, 300) / 1000)
        end
    end)
    
    -- Phase 2: Logo entrance with bounce
    task.wait(0.3)
    LogoContainer.BackgroundTransparency = 0.3
    TweenService:Create(LogoContainer, TweenInfo.new(0.8, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 140, 0, 140)
    }):Play()
    TweenService:Create(LogoStroke, TweenInfo.new(0.5), {Transparency = 0}):Play()
    TweenService:Create(LogoImage, TweenInfo.new(0.6), {ImageTransparency = 0}):Play()
    TweenService:Create(LogoGlow, TweenInfo.new(0.8), {ImageTransparency = 0.4}):Play()
    
    -- Start logo animations
    FloatElement(LogoContainer, 8, 1.5)
    ColorCycle(LogoStroke, "Color", {Colors.Accent, Colors.Primary, Colors.Gold}, 1.2)
    PulseElement(LogoGlow, "ImageTransparency", 0.3, 0.7, 1)
    
    -- Phase 3: Fire emojis
    task.wait(0.4)
    TweenService:Create(LeftFire, TweenInfo.new(0.5, Enum.EasingStyle.Back), {TextTransparency = 0}):Play()
    TweenService:Create(RightFire, TweenInfo.new(0.5, Enum.EasingStyle.Back), {TextTransparency = 0}):Play()
    
    -- Animate fire emojis
    FloatElement(LeftFire, 10, 0.8)
    FloatElement(RightFire, 10, 0.9)
    
    task.spawn(function()
        while LeftFire and LeftFire.Parent do
            TweenService:Create(LeftFire, TweenInfo.new(0.3), {Rotation = -15}):Play()
            TweenService:Create(RightFire, TweenInfo.new(0.3), {Rotation = 15}):Play()
            task.wait(0.3)
            TweenService:Create(LeftFire, TweenInfo.new(0.3), {Rotation = 15}):Play()
            TweenService:Create(RightFire, TweenInfo.new(0.3), {Rotation = -15}):Play()
            task.wait(0.3)
        end
    end)
    
    -- Phase 4: Title with slam effect
    task.wait(0.3)
    TitleLabel.Position = UDim2.new(0, 0, 0.25, 0)
    TweenService:Create(TitleLabel, TweenInfo.new(0.4, Enum.EasingStyle.Back), {
        TextTransparency = 0,
        Position = UDim2.new(0, 0, 0.35, 0)
    }):Play()
    TweenService:Create(TitleStroke, TweenInfo.new(0.3), {Transparency = 0}):Play()
    
    task.wait(0.1)
    ShakeElement(TitleLabel, 3, 0.2)
    
    -- Title glow animation
    ColorCycle(TitleStroke, "Color", {Colors.Primary, Colors.Accent, Colors.Glow1}, 0.8)
    
    -- Phase 5: Version badge
    task.wait(0.2)
    VersionBadge.BackgroundTransparency = 0.1
    TweenService:Create(VersionBadge, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
        TextTransparency = 0,
        Size = UDim2.new(0, 80, 0, 30)
    }):Play()
    
    PulseElement(VersionBadge, "BackgroundTransparency", 0.1, 0.4, 0.8)
    
    -- Phase 6: Announcement box
    task.wait(0.3)
    AnnouncementContainer.BackgroundTransparency = 0.5
    TweenService:Create(AnnouncementContainer, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {
        BackgroundTransparency = 0.15
    }):Play()
    TweenService:Create(AnnouncementStroke, TweenInfo.new(0.4), {Transparency = 0}):Play()
    TweenService:Create(AnnouncementGlow, TweenInfo.new(0.6), {ImageTransparency = 0.5}):Play()
    TweenService:Create(AnnouncementIcon, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    
    -- Announcement box animations
    ColorCycle(AnnouncementStroke, "Color", {Colors.Gold, Colors.Accent, Colors.White}, 1)
    PulseElement(AnnouncementGlow, "ImageTransparency", 0.4, 0.8, 1.2)
    
    -- Phase 7: Type out announcement text
    task.wait(0.3)
    task.spawn(function()
        TypeText(AnnouncementText, Config.ANNOUNCEMENT_TEXT, 0.04)
        
        -- Flash effect after typing
        TweenService:Create(AnnouncementText, TweenInfo.new(0.1), {TextColor3 = Colors.White}):Play()
        task.wait(0.1)
        TweenService:Create(AnnouncementText, TweenInfo.new(0.3), {TextColor3 = Colors.Gold}):Play()
        
        -- Start text pulse
        PulseElement(AnnouncementText, "TextSize", 22, 26, 1)
    end)
    
    -- Subtext fade in
    task.wait(1.5)
    TweenService:Create(SubText, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
    
    -- Phase 8: Discord button entrance
    task.wait(0.4)
    DiscordButton.BackgroundTransparency = 0
    ButtonContainer.Position = UDim2.new(0.5, 0, 0.85, 0)
    
    TweenService:Create(ButtonContainer, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, 0, 0.72, 0)
    }):Play()
    TweenService:Create(ButtonStroke, TweenInfo.new(0.4), {Transparency = 0}):Play()
    TweenService:Create(ButtonGlow, TweenInfo.new(0.5), {ImageTransparency = 0.5}):Play()
    TweenService:Create(ButtonIcon, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(ButtonText, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
    TweenService:Create(ButtonSubtext, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
    
    -- Button animations
    PulseElement(ButtonGlow, "ImageTransparency", 0.4, 0.8, 1)
    ColorCycle(ButtonStroke, "Color", {Color3.fromRGB(130, 140, 255), Color3.fromRGB(180, 180, 255), Color3.fromRGB(100, 120, 255)}, 0.8)
    
    task.spawn(function()
        while ButtonIcon and ButtonIcon.Parent do
            TweenService:Create(ButtonIcon, TweenInfo.new(0.5, Enum.EasingStyle.Bounce), {Rotation = -10}):Play()
            task.wait(0.5)
            TweenService:Create(ButtonIcon, TweenInfo.new(0.5, Enum.EasingStyle.Bounce), {Rotation = 10}):Play()
            task.wait(0.5)
        end
    end)
    
    -- Phase 9: Close button
    task.wait(0.3)
    CloseButton.BackgroundTransparency = 0.2
    TweenService:Create(CloseButton, TweenInfo.new(0.4, Enum.EasingStyle.Back), {
        TextTransparency = 0
    }):Play()
    TweenService:Create(CloseStroke, TweenInfo.new(0.3), {Transparency = 0}):Play()
    
    -- Close button pulse
    PulseElement(CloseButton, "BackgroundTransparency", 0.2, 0.5, 1)
    
    -- Phase 10: Footer
    task.wait(0.2)
    TweenService:Create(Footer, TweenInfo.new(0.5), {TextTransparency = 0.3}):Play()
end)

