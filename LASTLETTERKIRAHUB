-- Create floating particles
local function CreateParticle()
    local particle = Instance.new("Frame")
    particle.Size = UDim2.new(0, math.random(3, 8), 0, math.random(3, 8))
    particle.Position = UDim2.new(math.random(0, 100)/100, 0, 1.1, 0)
    particle.BackgroundColor3 = math.random() > 0.5 and Colors.Accent or Colors.Primary
    particle.BackgroundTransparency = math.random(30, 70)/100
    particle.BorderSizePixel = 0
    particle.Parent = ParticleContainer
    Instance.new("UICorner", particle).CornerRadius = UDim.new(1, 0)
    
    -- Glow for particle
    local particleGlow = Instance.new("ImageLabel")
    particleGlow.Size = UDim2.new(3, 0, 3, 0)
    particleGlow.Position = UDim2.new(0.5, 0, 0.5, 0)
    particleGlow.AnchorPoint = Vector2.new(0.5, 0.5)
    particleGlow.BackgroundTransparency = 1
    particleGlow.Image = "rbxassetid://5028857084"
    particleGlow.ImageColor3 = particle.BackgroundColor3
    particleGlow.ImageTransparency = 0.5
    particleGlow.ScaleType = Enum.ScaleType.Slice
    particleGlow.SliceCenter = Rect.new(24, 24, 276, 276)
    particleGlow.Parent = particle
    
    local duration = math.random(4, 8)
    local xOffset = math.random(-100, 100)
    
    TweenService:Create(particle, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
        Position = UDim2.new(particle.Position.X.Scale, xOffset, -0.1, 0),
        BackgroundTransparency = 1,
        Rotation = math.random(-180, 180)
    }):Play()
    
    task.delay(duration, function()
        particle:Destroy()
    end)
end

