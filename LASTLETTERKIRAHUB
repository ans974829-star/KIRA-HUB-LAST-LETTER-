-- Close Function
local function CloseAnnouncement()
    -- Cinematic exit
    SmoothTween(MainCard, 0.6, {Position = UDim2.new(0.5, 0, 0.55, 0), BackgroundTransparency = 1}, Enum.EasingStyle.Quint, Enum.EasingDirection.In):Play()
    SmoothTween(MainCardStroke, 0.4, {Transparency = 1}, Enum.EasingStyle.Quint):Play()
    SmoothTween(CardGlow, 0.4, {ImageTransparency = 1}, Enum.EasingStyle.Quint):Play()
    
    -- Fade all elements
    for _, desc in pairs(MainCard:GetDescendants()) do
        if desc:IsA("TextLabel") then
            SmoothTween(desc, 0.3, {TextTransparency = 1}, Enum.EasingStyle.Quint):Play()
        end
        if desc:IsA("TextButton") then
            SmoothTween(desc, 0.3, {BackgroundTransparency = 1}, Enum.EasingStyle.Quint):Play()
        end
        if desc:IsA("Frame") and desc.BackgroundTransparency < 1 then
            SmoothTween(desc, 0.3, {BackgroundTransparency = 1}, Enum.EasingStyle.Quint):Play()
        end
        if desc:IsA("ImageLabel") then
            SmoothTween(desc, 0.3, {ImageTransparency = 1}, Enum.EasingStyle.Quint):Play()
        end
        if desc:IsA("UIStroke") then
            SmoothTween(desc, 0.3, {Transparency = 1}, Enum.EasingStyle.Quint):Play()
        end
    end
    
    task.wait(0.25)
    
    SmoothTween(CinematicTop, 0.6, {Position = UDim2.new(0, 0, -0.08, 0)}, Enum.EasingStyle.Quint):Play()
    SmoothTween(CinematicBottom, 0.6, {Position = UDim2.new(0, 0, 1, 0)}, Enum.EasingStyle.Quint):Play()
    
    SmoothTween(BackgroundImage, 0.6, {ImageTransparency = 1}, Enum.EasingStyle.Quint):Play()
    SmoothTween(DarkOverlay, 0.5, {BackgroundTransparency = 1}, Enum.EasingStyle.Quint):Play()
    SmoothTween(Vignette, 0.5, {ImageTransparency = 1}, Enum.EasingStyle.Quint):Play()
    SmoothTween(BlurEffect, 0.6, {Size = 0}, Enum.EasingStyle.Quint):Play()
    SmoothTween(ColorCorrection, 0.5, {Brightness = 0, Contrast = 0, Saturation = 0}, Enum.EasingStyle.Quint):Play()
    
    task.wait(0.6)
    
    BlurEffect:Destroy()
    ColorCorrection:Destroy()
    ScreenGui:Destroy()
end

ContinueButton.MouseButton1Click:Connect(CloseAnnouncement)
CloseButton.MouseButton1Click:Connect(CloseAnnouncement)

-- Keyboard
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Escape or input.KeyCode == Enum.KeyCode.Return then
        CloseAnnouncement()
    end
end)

