local function CreateLightBeam()
    local beam = Instance.new("Frame")
    beam.Size = UDim2.new(0, math.random(100, 300), 0, 2000)
    beam.Position = UDim2.new(math.random(0, 100)/100, 0, 0.5, 0)
    beam.AnchorPoint = Vector2.new(0.5, 0.5)
    beam.Rotation = math.random(-30, 30)
    beam.BackgroundTransparency = 1
    beam.BorderSizePixel = 0
    beam.ZIndex = 1
    beam.Parent = LightBeamContainer
    
    local beamGradient = Instance.new("UIGradient")
    beamGradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
        ColorSequenceKeypoint.new(0.4, Colors.PrimaryGlow),
        ColorSequenceKeypoint.new(0.6, Colors.PrimaryGlow),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
    }
    beamGradient.Rotation = 90
    beamGradient.Parent = beam
    
    beam.BackgroundColor3 = Colors.PrimaryGlow
    
    TweenService:Create(beam, TweenInfo.new(0.8, Enum.EasingStyle.Quint), {
        BackgroundTransparency = 0.92
    }):Play()
    
    TweenService:Create(beam, TweenInfo.new(8, Enum.EasingStyle.Linear), {
        Position = UDim2.new(beam.Position.X.Scale + 0.3, 0, 0.5, 0),
        Rotation = beam.Rotation + 10
    }):Play()
    
    task.delay(2, function()
        TweenService:Create(beam, TweenInfo.new(2, Enum.EasingStyle.Quint), {
            BackgroundTransparency = 1
        }):Play()
    end)
    
    task.delay(4, function()
        if beam then beam:Destroy() end
    end)
end

