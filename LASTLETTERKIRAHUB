local function CreateFloatingParticle()
    local particle = Instance.new("Frame")
    particle.Size = UDim2.new(0, math.random(2, 5), 0, math.random(2, 5))
    particle.Position = UDim2.new(math.random(0, 100)/100, 0, 1.05, 0)
    particle.BackgroundColor3 = Color3.fromHSV(math.random(0, 20)/360, 0.8, 1)
    particle.BackgroundTransparency = math.random(40, 70)/100
    particle.BorderSizePixel = 0
    particle.ZIndex = 2
    particle.Parent = ParticleContainer
    CreateCorner(particle, 50)
    
    local duration = math.random(8, 15)
    local xDrift = math.random(-80, 80)
    
    TweenService:Create(particle, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
        Position = UDim2.new(particle.Position.X.Scale, xDrift, -0.1, 0),
        BackgroundTransparency = 1,
        Size = UDim2.new(0, math.random(1, 3), 0, math.random(1, 3))
    }):Play()
    
    task.delay(duration, function()
        if particle then particle:Destroy() end
    end)
end

